<header class="mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
  <hgroup>
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight"><%= title %></h1>
    <% if local_assigns[:subtitle] %>
      <p class="mt-1 text-slate-500 text-sm sm:text-base"><%= subtitle %></p>
    <% end %>
  </hgroup>
  <% if local_assigns[:actions] %>
    <p class="flex flex-wrap gap-2 shrink-0 m-0"><%= actions %></p>
  <% end %>
</header>
