<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between gap-4">
      <%= link_to root_path, class: "flex items-center gap-2 shrink-0" do %>
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-indigo-600 to-violet-600 text-white text-sm font-bold shadow-sm">H</span>
        <span class="text-lg font-bold text-slate-900">HireFlow <span class="text-indigo-600">AI</span></span>
      <% end %>

      <div class="flex flex-wrap items-center justify-end gap-1 sm:gap-2 text-sm font-medium">
        <%= link_to "Jobs", jobs_path, class: "px-3 py-2 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition" %>

        <% if user_signed_in? %>
          <%= link_to "Dashboard", dashboard_path, class: "px-3 py-2 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition" %>
          <% if current_user.recruiter? %>
            <%= link_to "Pipeline", recruiter_pipeline_index_path, class: "px-3 py-2 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition" %>
          <% end %>
          <% if current_user.candidate? %>
            <%= link_to "Resume", resume_path, class: "px-3 py-2 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition" %>
          <% end %>
          <%= link_to notifications_path, class: "relative px-3 py-2 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition" do %>
            <span class="sr-only">Notifications</span>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
            <%= turbo_stream_from "notifications_#{current_user.id}" %>
            <span id="notification_badge" class="absolute -top-0.5 -right-0.5">
              <%= render "notifications/badge", count: current_user.notifications.unread.count %>
            </span>
          <% end %>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_dashboard_path, class: "px-3 py-2 rounded-lg text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition" %>
          <% end %>

          <span class="hidden sm:inline-flex items-center gap-2 ml-2 pl-3 border-l border-slate-200">
            <span class="text-slate-700 truncate max-w-[120px]"><%= current_user.name %></span>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold <%= role_badge_class(current_user.role) %>"><%= current_user.role %></span>
          </span>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "ml-1 px-3 py-2 rounded-lg text-slate-500 hover:text-red-600 hover:bg-red-50 text-sm font-medium transition" %>
        <% else %>
          <%= link_to "Sign in", new_user_session_path, class: "px-3 py-2 rounded-lg text-slate-600 hover:text-indigo-600 transition" %>
          <%= link_to "Sign up", new_user_registration_path, class: "#{btn_primary('!py-2 !px-4')}" %>
        <% end %>
      </div>
    </div>
  </nav>
</header>
