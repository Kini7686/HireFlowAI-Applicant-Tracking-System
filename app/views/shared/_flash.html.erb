<% if notice.present? %>
  <aside class="bg-emerald-50 border-b border-emerald-200 px-4 py-3" role="alert">
    <p class="max-w-7xl mx-auto text-sm font-medium text-emerald-800 text-center"><%= notice %></p>
  </aside>
<% end %>
<% if alert.present? %>
  <aside class="bg-red-50 border-b border-red-200 px-4 py-3" role="alert">
    <p class="max-w-7xl mx-auto text-sm font-medium text-red-800 text-center"><%= alert %></p>
  </aside>
<% end %>
