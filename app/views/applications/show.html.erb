<%= link_to "← Back", :back, class: "#{btn_ghost('mb-6 inline-flex')}" %>

<%= turbo_stream_from @application %>
<%= turbo_stream_from "candidate_applications_#{current_user.id}" if current_user.candidate? %>

<header class="mb-6">
  <h1 class="text-2xl sm:text-3xl font-bold text-slate-900"><%= @application.job.title %></h1>
  <p class="text-slate-500 mt-1">Applicant: <span class="font-medium text-slate-700"><%= @application.user.name %></span></p>
  <p class="mt-3">
    <%= turbo_frame_tag "application_status_#{@application.id}" do %>
      <%= render "applications/status_badge", application: @application %>
    <% end %>
  </p>
</header>

<%= render "applications/ats_score", application: @application %>

<% if current_user.recruiter? || current_user.admin? %>
  <article class="<%= card_classes %> p-6 mt-6">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-4">Recruiter actions</h2>
    <%= turbo_frame_tag "status_update_form" do %>
      <%= form_with model: @application, url: application_path(@application), method: :patch, class: "space-y-4 max-w-lg" do |f| %>
        <p>
          <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :status, Application.statuses.keys.map { |s| [s.humanize, s] }, {}, class: input_classes %>
        </p>
        <p>
          <%= f.label :recruiter_notes, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_area :recruiter_notes, rows: 4, class: input_classes, placeholder: "Internal notes for this candidate…" %>
        </p>
        <%= f.submit "Update application", class: btn_primary %>
      <% end %>
    <% end %>
  </article>
<% end %>
