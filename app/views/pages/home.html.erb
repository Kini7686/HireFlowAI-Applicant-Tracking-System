<section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-600 via-indigo-700 to-violet-800 text-white px-6 py-16 sm:py-20 mb-12 shadow-xl">
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] opacity-50"></div>
  <div class="relative max-w-3xl mx-auto text-center">
    <p class="text-indigo-200 text-sm font-semibold uppercase tracking-widest mb-3">AI-Powered Hiring</p>
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">Hire smarter with HireFlow AI</h1>
    <p class="text-lg text-indigo-100 mb-8 max-w-xl mx-auto">
      Full-stack applicant tracking built with Ruby on Rails, Hotwire, and Sidekiq — resume parsing, ATS scoring, and real-time pipelines.
    </p>
    <p class="flex flex-col sm:flex-row justify-center gap-3">
      <%= link_to "Browse open roles", jobs_path, class: "inline-flex justify-center px-6 py-3 rounded-lg bg-white text-indigo-700 font-semibold shadow-lg hover:bg-indigo-50 transition" %>
      <%= link_to "Create account", new_user_registration_path, class: "inline-flex justify-center px-6 py-3 rounded-lg border-2 border-white/80 text-white font-semibold hover:bg-white/10 transition" %>
    </p>
  </div>
</section>

<section class="grid sm:grid-cols-3 gap-6 mb-12">
  <article class="<%= card_classes %> p-6">
    <span class="text-2xl mb-3 block" aria-hidden="true">📄</span>
    <h2 class="font-semibold text-slate-900 mb-1">Resume parsing</h2>
    <p class="text-sm text-slate-500">Upload PDF resumes and extract skills, education, and experience automatically.</p>
  </article>
  <article class="<%= card_classes %> p-6">
    <span class="text-2xl mb-3 block" aria-hidden="true">🎯</span>
    <h2 class="font-semibold text-slate-900 mb-1">ATS scoring</h2>
    <p class="text-sm text-slate-500">Match candidates to job requirements with keyword-based scoring and AI feedback.</p>
  </article>
  <article class="<%= card_classes %> p-6">
    <span class="text-2xl mb-3 block" aria-hidden="true">⚡</span>
    <h2 class="font-semibold text-slate-900 mb-1">Live updates</h2>
    <p class="text-sm text-slate-500">Turbo Streams and Sidekiq keep recruiters and candidates in sync.</p>
  </article>
</section>

<% unless user_signed_in? %>
  <section class="<%= card_classes %> p-8 text-center">
    <h2 class="text-xl font-bold text-slate-900 mb-2">Ready to get started?</h2>
    <p class="text-slate-500 mb-4">Sign up as a candidate or recruiter to access your dashboard.</p>
    <%= link_to "Sign up free", new_user_registration_path, class: btn_primary %>
  </section>
<% end %>
