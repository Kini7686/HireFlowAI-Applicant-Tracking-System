<%= render "shared/page_header",
      title: "Application pipeline",
      subtitle: "Drag cards between stages to update status" %>

<%= turbo_stream_from "recruiter_pipeline" %>

<section class="flex gap-3 overflow-x-auto pb-4" data-controller="pipeline">
  <% Application.statuses.keys.each do |status| %>
    <article class="flex-shrink-0 w-64 <%= card_classes %> p-3 min-h-[280px] bg-slate-50/80" data-pipeline-target="column" data-status="<%= status %>">
      <header class="flex items-center justify-between mb-3 pb-2 border-b border-slate-200">
        <h2 class="text-xs font-bold uppercase tracking-wider text-slate-600"><%= status.humanize %></h2>
        <span class="text-xs font-semibold text-slate-400 bg-white px-2 py-0.5 rounded-full"><%= (@grouped[status] || []).size %></span>
      </header>
      <% (@grouped[status] || []).each do |application| %>
        <section id="pipeline_card_<%= application.id %>"
                 class="bg-white rounded-lg border border-slate-200 shadow-sm p-3 mb-2 cursor-grab active:cursor-grabbing hover:border-indigo-300 transition"
                 draggable="true"
                 data-id="<%= application.id %>"
                 data-action="dragstart->pipeline#dragStart dragend->pipeline#dragEnd">
          <p class="font-semibold text-sm text-slate-900 truncate"><%= application.user.name %></p>
          <p class="text-xs text-slate-500 truncate mt-0.5"><%= application.job.title %></p>
          <% if application.ats_score %>
            <p class="mt-2 inline-flex px-2 py-0.5 rounded text-xs font-bold <%= ats_score_bg(application.ats_score) %> <%= ats_score_color(application.ats_score) %>">
              <%= application.ats_score %>% ATS
            </p>
          <% end %>
          <%= link_to "View →", application_path(application), class: "text-xs font-semibold text-indigo-600 mt-2 inline-block" %>
        </section>
      <% end %>
    </article>
  <% end %>
</section>
