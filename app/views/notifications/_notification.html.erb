<li class="<%= card_classes %> p-4 <%= 'opacity-60' if notification.read? %> hover:shadow-md transition">
  <p class="flex items-start justify-between gap-2">
    <span class="font-semibold text-slate-900"><%= notification.title %></span>
    <% unless notification.read? %>
      <span class="shrink-0 h-2 w-2 rounded-full bg-indigo-500" title="Unread"></span>
    <% end %>
  </p>
  <p class="text-sm text-slate-600 mt-1"><%= notification.message %></p>
  <p class="text-xs text-slate-400 mt-2"><%= time_ago_in_words(notification.created_at) %> ago</p>
  <% unless notification.read? %>
    <%= button_to "Mark read", notification_path(notification), method: :patch, class: "text-xs font-semibold text-indigo-600 mt-2 hover:underline" %>
  <% end %>
</li>
