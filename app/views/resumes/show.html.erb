<%= render "shared/page_header",
      title: "Resume",
      subtitle: "Upload your PDF and view parsed profile data" %>

<%= turbo_stream_from "resume_profile_#{current_user.id}" %>

<section class="grid lg:grid-cols-2 gap-6">
  <article class="<%= card_classes %> p-6 sm:p-8" data-controller="resume-upload">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-4">Upload PDF</h2>
    <%= form_with url: resume_path, method: current_user.resume.attached? ? :patch : :post, multipart: true, class: "space-y-4" do %>
      <label class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-slate-300 rounded-xl bg-slate-50 hover:bg-indigo-50/50 hover:border-indigo-300 transition cursor-pointer">
        <span class="text-slate-500 text-sm text-center px-4">Click to select PDF or drag file here</span>
        <%= file_field_tag :resume, accept: "application/pdf", class: "sr-only", data: { resume_upload_target: "input", action: "change->resume-upload#preview" } %>
      </label>
      <p data-resume-upload-target="preview" class="text-sm text-slate-500 text-center"></p>
      <%= submit_tag current_user.resume.attached? ? "Replace resume" : "Upload resume", class: "#{btn_primary('w-full')}" %>
    <% end %>
    <% if current_user.resume.attached? %>
      <p class="mt-4 text-sm text-slate-600 flex items-center gap-2">
        <span aria-hidden="true">📎</span> <%= current_user.resume.filename %>
      </p>
    <% end %>
  </article>

  <article class="<%= card_classes %> p-6 sm:p-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-4">Parsed profile</h2>
    <span id="resume_processing_status">
      <%= render "resumes/processing_status", profile: @profile %>
    </span>
    <% if @profile&.completed? && Array(@profile.parsed_skills).any? %>
      <section class="mt-6">
        <h3 class="text-sm font-semibold text-slate-700 mb-2">Skills detected</h3>
        <p class="flex flex-wrap gap-1.5">
          <% Array(@profile.parsed_skills).each do |skill| %>
            <span class="px-2.5 py-1 bg-indigo-50 text-indigo-800 rounded-full text-xs font-medium"><%= skill %></span>
          <% end %>
        </p>
      </section>
    <% end %>
    <% if @profile&.completed? && @profile.parsed_education.present? %>
      <section class="mt-4">
        <h3 class="text-sm font-semibold text-slate-700 mb-2">Education</h3>
        <pre class="text-xs bg-slate-50 border border-slate-200 rounded-lg p-3 overflow-x-auto text-slate-600"><%= JSON.pretty_generate(@profile.parsed_education) %></pre>
      </section>
    <% end %>
  </article>
</section>
