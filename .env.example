# Database (Docker uses DATABASE_HOST=db automatically)
DATABASE_HOST=db
DATABASE_USERNAME=hireflow
DATABASE_PASSWORD=hireflow
DATABASE_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Rails
SECRET_KEY_BASE=change_me_to_a_long_random_string_in_production
RAILS_ENV=development

# Active Storage (local = free, no AWS needed)
ACTIVE_STORAGE_SERVICE=local

# Optional: AWS S3 for resume storage in production
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=hireflow-resumes

# Optional: OpenAI for enhanced feedback (fallback works without this)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
